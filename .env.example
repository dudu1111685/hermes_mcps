# WAHA MCP Server Configuration

# WAHA instance URL (default: http://localhost:3001)
WAHA_URL=http://localhost:3001

# WAHA API Key (REQUIRED)
WAHA_API_KEY=your-api-key-here

# Soniox Speech-to-Text API key (optional — enables voice message transcription
# in waha_get_chat_context and waha_transcribe_message; get one at https://soniox.com)
# SONIOX_API_KEY=your-soniox-key

# HTTP timeout for WAHA requests in milliseconds (optional, default 30000)
# WAHA_TIMEOUT_MS=30000

# Default session name (optional, defaults to "default")
# WAHA_DEFAULT_SESSION=default
